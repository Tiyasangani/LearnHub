@model List<LearnHub.Models.Course>
@{
    ViewData["Title"] = "Courses";
    var categories = ViewBag.Categories as string[] ?? Array.Empty<string>();
    var activeCategory = ViewBag.Category as string ?? "All";
    var search = ViewBag.Search as string ?? "";
}

<!-- ── Hero ───────────────────────────────────────────────────────────── -->
<section class="lh-courses-hero">
    <div class="container text-center">
        <h1 class="fw-bold text-white mb-2">Explore Our Courses</h1>
        <p class="text-white-50 mb-4">Find the perfect course to advance your skills and career.</p>
        <form asp-action="Index" method="get" class="d-flex justify-content-center">
            <div class="lh-search-wrap">
                <i class="bi bi-search lh-search-icon"></i>
                <input name="search" value="@search" type="text" class="form-control lh-search-input"
                       placeholder="Search courses or instructors..." />
                <input type="hidden" name="category" value="@activeCategory" />
            </div>
        </form>
    </div>
</section>

<!-- ── Filters + Grid ─────────────────────────────────────────────────── -->
<div class="container py-4">
    <!-- Category pills -->
    <div class="lh-filter-bar mb-4">
        @foreach (var cat in categories)
        {
            <a asp-action="Index" asp-route-category="@cat" asp-route-search="@search"
               class="lh-filter-pill @(activeCategory == cat ? "active" : "")">@cat</a>
        }
    </div>

    <p class="text-muted small mb-3">Showing @Model.Count course@(Model.Count != 1 ? "s" : "")</p>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-3 text-muted"></i>
            <h4 class="mt-3">No courses found</h4>
            <p class="text-muted">Try a different search term or category.</p>
            <a asp-action="Index" class="btn btn-primary">Clear Filters</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                @await Html.PartialAsync("_CourseCard", course)
            }
        </div>
    }
</div>
