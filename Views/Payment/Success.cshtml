@{
    ViewData["Title"] = "Enrollment Successful";
    var courseId = ViewBag.CourseId;
    var courseTitle = ViewBag.CourseTitle as string ?? "your course";
}

<div class="container py-5 text-center">
    <div class="lh-success-icon mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size:4rem;"></i>
    </div>
    <h2 class="fw-bold mb-2">You're Enrolled!</h2>
    <p class="text-muted mb-4">You've successfully enrolled in <strong>@courseTitle</strong>.</p>
    <div class="d-flex justify-content-center gap-3">
        @if (courseId != null)
        {
            <a asp-controller="Quiz" asp-action="Take" asp-route-courseId="@courseId"
               class="btn btn-primary px-4">Take Quiz Now</a>
        }
        <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-secondary px-4">Browse More Courses</a>
    </div>
</div>
