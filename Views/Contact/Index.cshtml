@model LearnHub.Models.ContactMessage
@{
    ViewData[" Title "] = " Contact Us ";
}

<!-- Hero -->
<section style="background:linear-gradient(135deg,#1a1a2e,#16213e);padding:60px 0;" class="text-white text-center">
    <div class="container">
        <h1 class="fw-bold mb-2"> Get in Touch </h1>
        <p class="text-white-50">Have a question? We'd love to hear from you.</p>
    </div>
</section>

<div class="container py-5">
    <div class="row g-4 justify-content-center">
        <!-- Info cards -->
        <div class="col-lg-4">
            <div class="d-flex flex-column gap-3">
                <div class="lh-card p-4 d-flex gap-3 align-items-start">
                    <div class="lh-contact-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-envelope"></i></div>
                    <div><h6 class="fw-semibold mb-1">Email Us</h6><p class="text-muted small mb-0">support@learnhub.com</p></div>
                </div>
                <div class="lh-card p-4 d-flex gap-3 align-items-start">
                    <div class="lh-contact-icon bg-success bg-opacity-10 text-success"><i class="bi bi-telephone"></i></div>
                    <div><h6 class="fw-semibold mb-1">Call Us</h6><p class="text-muted small mb-0">+91 98765 43210</p></div>
                </div>
                <div class="lh-card p-4 d-flex gap-3 align-items-start">
                    <div class="lh-contact-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-geo-alt"></i></div>
                    <div><h6 class="fw-semibold mb-1">Office</h6><p class="text-muted small mb-0">Mumbai, Maharashtra, India</p></div>
                </div>
            </div>
        </div>

        <!-- Form -->
        <div class="col-lg-7">
            <div class="lh-card p-4 p-md-5">
                <h5 class="fw-bold mb-4">Send a Message</h5>

                @if (TempData[" Success "] != null)
                {
                    <div class="alert alert-success">@TempData[" Success "]</div>
                }

                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Name</label>
                            <input asp-for="Name" class="form-control" placeholder="TIA" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Subject</label>
                            <input asp-for="Subject" class="form-control" placeholder="How can we help?" />
                            <span asp-validation-for="Subject" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Message</label>
                            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Your message..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary px-5 mt-3 fw-semibold">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>
