@model LearnHub.Models.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
    var userName = Context.Session.GetString("UserName") ?? "User";
}

<div class="container py-5" style="max-width:680px;">

    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="ep-avatar">@userName[0]</div>
        <div>
            <h4 class="fw-bold mb-0">Edit Profile</h4>
            <p class="text-muted small mb-0">Update your account information</p>
        </div>
    </div>

    <div class="lh-card p-4 mb-4">
        <form asp-action="EditProfile" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <!-- Personal Info -->
            <h6 class="fw-bold text-primary mb-3 pb-2 border-bottom">
                <i class="bi bi-person-fill me-2"></i>Personal Information
            </h6>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Full Name</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-person lh-input-icon"></i>
                    <input asp-for="FullName" class="form-control lh-input" placeholder="John Doe" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-semibold">Email Address</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-envelope lh-input-icon"></i>
                    <input asp-for="Email" class="form-control lh-input" placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- Change Password -->
            <h6 class="fw-bold text-primary mb-3 pb-2 border-bottom">
                <i class="bi bi-lock-fill me-2"></i>Change Password
                <span class="text-muted fw-normal small">(leave blank to keep current)</span>
            </h6>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Current Password</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-lock lh-input-icon"></i>
                    <input asp-for="CurrentPassword" type="password" class="form-control lh-input" placeholder="Enter current password" />
                </div>
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-semibold">New Password</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-lock lh-input-icon"></i>
                    <input asp-for="NewPassword" type="password" id="newPass" class="form-control lh-input" placeholder="At least 6 characters" />
                    <button type="button" class="lh-eye-btn" onclick="togglePass('newPass','eye1')">
                        <i class="bi bi-eye" id="eye1"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-semibold">Confirm New Password</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-lock lh-input-icon"></i>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control lh-input" placeholder="Repeat new password" />
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 fw-semibold">
                    <i class="bi bi-save me-1"></i> Save Changes
                </button>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
            </div>
        </form>
    </div>

    <!-- Danger zone -->
    <div class="lh-card p-4 border-danger">
        <h6 class="fw-bold text-danger mb-2"><i class="bi bi-exclamation-triangle me-2"></i>Account Actions</h6>
        <p class="text-muted small mb-3">These actions are permanent and cannot be undone.</p>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i> Log Out of All Devices
        </a>
    </div>
</div>

<style>
.ep-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; font-weight: 800;
}
</style>

@section Scripts {
<script>
function togglePass(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    input.type = input.type === 'password' ? 'text' : 'password';
    icon.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}
</script>
}
