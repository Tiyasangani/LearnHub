@{
    ViewData["Title"] = "Forgot Password";
}

<div class="lh-auth-page">
    <div class="lh-auth-card">
        <div class="text-center mb-4">
            <div class="lh-auth-logo"><i class="bi bi-journal-bookmark-fill"></i></div>
            <h4 class="fw-bold mt-3">Reset your password</h4>
            <p class="text-muted small">Enter your email and we'll send you a reset link</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label small fw-semibold">Email</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-envelope lh-input-icon"></i>
                    <input name="email" type="email" class="form-control lh-input" placeholder="you@example.com" required />
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">Send Reset Link</button>
            <p class="text-center small mt-3 text-muted">
                Remember your password?
                <a asp-controller="Account" asp-action="Login" class="lh-link fw-semibold">Log in</a>
            </p>
        </form>
    </div>
</div>
