@model LearnHub.Models.LoginViewModel
@{
    ViewData["Title"] = "Log In";
}

<div class="lh-auth-page">
    <div class="lh-auth-card">
        <div class="text-center mb-4">
            <div class="lh-auth-logo"><i class="bi bi-journal-bookmark-fill"></i></div>
            <h4 class="fw-bold mt-3">Welcome back</h4>
            <p class="text-muted small">Log in to your Learnhub account</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Email</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-envelope lh-input-icon"></i>
                    <input asp-for="Email" class="form-control lh-input" placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-2">
                <label class="form-label small fw-semibold">Password</label>
                <div class="lh-input-wrap">
                    <i class="bi bi-lock lh-input-icon"></i>
                    <input asp-for="Password" type="password" id="passwordInput" class="form-control lh-input" placeholder="Enter your password" />
                    <button type="button" class="lh-eye-btn" onclick="togglePassword()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="text-end mb-3">
                <a asp-controller="Account" asp-action="ForgotPassword" class="lh-link small">Forgot Password?</a>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">Log In</button>

            <p class="text-center small mt-3 text-muted">
                Don't have an account?
                <a asp-controller="Account" asp-action="Register" class="lh-link fw-semibold">Sign up</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }
</script>
}
