<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LearnHub Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">

<div class="admin-wrapper">
    <!-- ── Sidebar ──────────────────────────────────────────────────── -->
    <aside class="admin-sidebar">
        <div class="admin-sidebar-brand">
            <span class="lh-logo-icon"><i class="bi bi-journal-bookmark-fill"></i></span>
            <div>
                <div class="fw-bold">LearnHub</div>
                <small class="text-muted">Admin Panel</small>
            </div>
        </div>
        <nav class="admin-nav mt-4">
            <a class="admin-nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Admin" asp-action="Index">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            <a class="admin-nav-link @(ViewData["ActivePage"]?.ToString() == "Courses" ? "active" : "")"
               asp-controller="Admin" asp-action="ManageCourses">
                <i class="bi bi-journal-text"></i> Manage Courses
            </a>
            <a class="admin-nav-link @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")"
               asp-controller="Admin" asp-action="ManageUsers">
                <i class="bi bi-people"></i> Manage Users
            </a>
            <a class="admin-nav-link @(ViewData["ActivePage"]?.ToString() == "AddCourse" ? "active" : "")"
               asp-controller="Admin" asp-action="AddCourse">
                <i class="bi bi-plus-circle"></i> Add Course
            </a>
        </nav>
        <div class="admin-sidebar-footer">
            <a asp-controller="Home" asp-action="Index" class="admin-nav-link text-danger">
                <i class="bi bi-box-arrow-left"></i> Back to Home
            </a>
        </div>
    </aside>

    <!-- ── Main content ─────────────────────────────────────────────── -->
    <main class="admin-main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
