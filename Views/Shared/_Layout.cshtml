<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LearnHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@{
    var userName = Context.Session.GetString("UserName");
    var isAdmin  = Context.Session.GetString("IsAdmin") == "True";
    var currentPath = Context.Request.Path.Value ?? "";
}

<!-- Navbar -->
<nav class="navbar navbar-expand-lg lh-navbar">
    <div class="container">
        <a class="navbar-brand lh-brand" asp-controller="Home" asp-action="Index">
            <span class="lh-logo-icon"><i class="bi bi-journal-bookmark-fill"></i></span>
            LearnHub
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(currentPath == "/" ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Courses") ? "active" : "")" asp-controller="Courses" asp-action="Index">Courses</a>
                </li>
                @if (userName != null)
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentPath.StartsWith("/Dashboard") ? "active" : "")" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Contact") ? "active" : "")" asp-controller="Contact" asp-action="Index">Contact</a>
                </li>
            </ul>
            <div class="d-flex align-items-center gap-2">
                @if (isAdmin)
                {
                    <a class="nav-admin-link" asp-controller="Admin" asp-action="Index">Admin</a>
                }
                @if (userName != null)
                {
                    <div class="dropdown">
                        <button class="lh-profile-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="lh-profile-avatar">@userName[0]</div>
                            <span class="d-none d-md-inline text-white-50 small ms-1">@userName</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end lh-dropdown shadow">
                            <li>
                                <div class="px-3 py-2 border-bottom">
                                    <div class="fw-semibold text-dark small">@userName</div>
                                    <div class="text-muted" style="font-size:.75rem;">Student Account</div>
                                </div>
                            </li>
                            <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-grid me-2 text-primary"></i>My Dashboard</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="EditProfile"><i class="bi bi-person-gear me-2 text-primary"></i>Edit Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Log Out</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Log In</a>
                    <a class="btn btn-primary btn-sm px-3" asp-controller="Account" asp-action="Register">Sign Up</a>
                }
            </div>
        </div>
    </div>
</nav>

<!-- Flash messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
        <div class="container">@TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
        <div class="container">@TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    </div>
}

<main>
    @RenderBody()
</main>

<!-- Footer -->
<footer class="lh-footer">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="lh-brand mb-3">
                    <span class="lh-logo-icon"><i class="bi bi-journal-bookmark-fill"></i></span>
                    Learnhub
                </div>
                <p class="text-muted small">Empowering learners worldwide with high-quality online courses taught by industry experts.</p>
                <div class="d-flex gap-2 mt-3">
                    <a href="#" class="lh-social-btn"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="lh-social-btn"><i class="bi bi-youtube"></i></a>
                    <a href="#" class="lh-social-btn"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="lh-social-btn"><i class="bi bi-github"></i></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <h6 class="text-uppercase text-white fw-semibold mb-3 small">Quick Links</h6>
                <ul class="list-unstyled lh-footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Courses" asp-action="Index">Courses</a></li>
                    <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                    <li><a asp-controller="Contact" asp-action="Index">Contact</a></li>
                </ul>
            </div>
            <div class="col-lg-3 col-md-6">
                <h6 class="text-uppercase text-white fw-semibold mb-3 small">Categories</h6>
                <ul class="list-unstyled lh-footer-links">
                    <li><a asp-controller="Courses" asp-action="Index" asp-route-category="Programming">Programming</a></li>
                    <li><a asp-controller="Courses" asp-action="Index" asp-route-category="Web Development">Web Development</a></li>
                    <li><a asp-controller="Courses" asp-action="Index" asp-route-category="Data Science">Data Science</a></li>
                    <li><a asp-controller="Courses" asp-action="Index" asp-route-category="Design">Design</a></li>
                    <li><a asp-controller="Courses" asp-action="Index" asp-route-category="Marketing">Marketing</a></li>
                </ul>
            </div>
            <div class="col-lg-3 col-md-6">
                <h6 class="text-uppercase text-white fw-semibold mb-3 small">Support</h6>
                <ul class="list-unstyled lh-footer-links">
                    <li><a href="#">Help Center</a></li>
                    <li><a href="#">Terms of Service</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Cookie Policy</a></li>
                </ul>
            </div>
        </div>
        <hr class="border-secondary mt-4" />
        <p class="text-center text-muted small mb-0">&copy; 2026 Learnhub. All rights reserved.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
